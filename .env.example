# ─────────────────────────────────────────────────────────────────────────────
# StellarPay Link — Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# Soroban smart contract address (deployed to Stellar Testnet).
# Obtain this after running: stellar contract deploy ...
# Leave blank to run in Level 1 mode (multi-wallet + send XLM only).
VITE_CONTRACT_ID=your_deployed_contract_id_here
